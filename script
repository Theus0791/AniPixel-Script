-- TP Suave (por cima da porta + descida)
local function tpToBoss(boss)
    if not boss or not boss:FindFirstChild("HumanoidRootPart") then return end

    -- 1. Sobe alto pra passar portal/porta
    local highPos = boss.HumanoidRootPart.Position + Vector3.new(0, 55, 0)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local root = char.HumanoidRootPart
        local tweenHigh = TweenService:Create(root, TweenInfo.new(1.5), {CFrame = CFrame.new(highPos)})
        tweenHigh:Play()
        tweenHigh.Completed:Wait()
    end
    wait(0.3)

    -- 2. Desce perto do boss
    local safePos = boss.HumanoidRootPart.Position + Vector3.new(0, 8, 0)
    if char and char:FindFirstChild("HumanoidRootPart") then
        local root = char.HumanoidRootPart
        local tweenDown = TweenService:Create(root, TweenInfo.new(0.9), {CFrame = CFrame.new(safePos)})
        tweenDown:Play()
        tweenDown.Completed:Wait()
    end
end

-- Encontrar boss mais próximo
local function findNearestBoss()
    local nearest = nil
    local minDist = math.huge
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and obj.Humanoid.Health > 0 then
            local name = obj.Name
            local dist = (obj.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if (table.find(BOSS_NAMES, name) or obj.Humanoid.MaxHealth > 5000) and dist < minDist then
                nearest = obj
                minDist = dist
            end
        end
    end
    return nearest
end

