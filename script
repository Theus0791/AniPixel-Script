local espConnections = {}

local function createESP(target)
    if espConnections[target] then return end
    if not target:FindFirstChild("Head") then return end

    local bb = Instance.new("BillboardGui", target.Head)
    bb.Name = "KIRA_ESP"
    bb.Size = UDim2.new(0, 240, 0, 70)
    bb.StudsOffset = Vector3.new(0, 4, 0)
    bb.AlwaysOnTop = true

    local nameLabel = Instance.new("TextLabel", bb)
    nameLabel.Size = UDim2.new(1,0,0.5,0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.new(1, 0.4, 1)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.Code

    local hpLabel = Instance.new("TextLabel", bb)
    hpLabel.Size = UDim2.new(1,0,0.5,0)
    hpLabel.Position = UDim2.new(0,0,0.5,0)
    hpLabel.BackgroundTransparency = 1
    hpLabel.TextColor3 = Color3.new(0,1,0)
    hpLabel.TextStrokeTransparency = 0
    hpLabel.TextScaled = true
    hpLabel.Font = Enum.Font.Code

    espConnections[target] = RunService.Heartbeat:Connect(function()
        if target.Parent and target:FindFirstChild("Humanoid") and target:FindFirstChild("HumanoidRootPart") then
            local dist = (target.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            nameLabel.Text = target.Name .. " [" .. math.floor(dist) .. "m]"
            hpLabel.Text = "HP: " .. math.floor(target.Humanoid.Health) .. "/" .. math.floor(target.Humanoid.MaxHealth)
        else
            bb:Destroy()
            espConnections[target]:Disconnect()
            espConnections[target] = nil
        end
    end)
end

local function clearESP()
    for target, conn in pairs(espConnections) do
        if conn then conn:Disconnect() end
        espConnections[target] = nil
    end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:FindFirstChild("KI'RA_ESP") then obj.KIRA_ESP:Destroy() end
    end
end

